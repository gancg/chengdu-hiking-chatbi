# 应用服务
CHATBI_DB_PATH=data/chatbi.db
CHATBI_SAMPLE_DATA_PATH=data/sample_routes.json
CHATBI_HOST=127.0.0.1
CHATBI_PORT=8000
CHATBI_WEB_HOST=127.0.0.1
CHATBI_WEB_PORT=7860
CHATBI_LOG_LEVEL=INFO
CHATBI_THIRD_PARTY_LOG_LEVEL=WARNING

# 对话模型（密钥值留空，仅在本机环境中填写）
DASHSCOPE_API_KEY=
CHATBI_QWEN_MODEL=qwen-max
CHATBI_QWEN_SEED=42
CHATBI_QWEN_MAX_LLM_CALLS=10
CHATBI_QWEN_MAX_RETRIES=2

# Provider
CHATBI_TRAFFIC_PROVIDER=none
CHATBI_ALERT_PROVIDER=qweather
QWEATHER_API_KEY=
QWEATHER_API_HOST=n32k5q6wdt.re.qweatherapi.com
CHATBI_WEATHER_REQUEST_TIMEOUT_SECONDS=10
CHATBI_WEATHER_CACHE_TTL_MINUTES=30

# 报团来源
CHATBI_YOUXIAKE_AROUND_URL=https://www.youxiake.com/around?site=19
CHATBI_YOUXIAKE_TIMEOUT_SECONDS=20
CHATBI_YOUXIAKE_MAX_LINKS=5
CHATBI_DAE_URL=https://www.cddee.cn/
CHATBI_DAE_TIMEOUT_SECONDS=20
CHATBI_DAE_MAX_LINKS=5
CHATBI_MIDO_URL=https://cdmdtb.360jlb.cn/events?mid=52240
CHATBI_MIDO_TIMEOUT_SECONDS=20
CHATBI_MIDO_MAX_LINKS=5

# 数据维护及采集管道
CHATBI_HOLIDAY_DATA_PATH=data/holidays.json
CHATBI_YOUXIAKE_LIST_URL=https://www.youxiake.com/search/results/0-0-0-1-0-0/azEtaTE.html
CHATBI_COLLECTOR_MODEL=qwen3.7-max
CHATBI_DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1/chat/completions
CHATBI_COLLECTOR_REQUEST_TIMEOUT_SECONDS=240
CHATBI_COLLECTOR_BROWSER_TIMEOUT_SECONDS=60
CHATBI_COLLECTOR_LINK_TIMEOUT_SECONDS=45
CHATBI_COLLECTOR_DEFAULT_COUNT=40
CHATBI_COLLECTOR_MAX_PAGES=30
CHATBI_COLLECTOR_INPUT_PATH=data/youxiake_chengdu_day_route_links_40.json
CHATBI_COLLECTOR_OUTPUT_PATH=data/youxiake_routes_enriched_40.json
CHATBI_COLLECTOR_LEGACY_OUTPUT_PATH=data/youxiake_chengdu_day_hikes_40.json
